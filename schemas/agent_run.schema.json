{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nourishos.dev/schemas/agent_run.schema.json",
  "title": "data/agent_runs/*.json — AgentRun (the replay-engine event contract; per PRD §11 this schema is also the v2 live API contract)",
  "type": "object",
  "additionalProperties": false,
  "required": ["client_id", "scenario", "events"],
  "properties": {
    "client_id": { "$ref": "defs.schema.json#/definitions/clientId" },
    "scenario": { "type": "string", "minLength": 1 },
    "generator": {
      "type": "string",
      "description": "Optional provenance: 'template' (deterministic) or a Claude model id that authored the reasoning offline"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "t_offset_ms", "agent", "type", "title", "detail"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "t_offset_ms": { "type": "integer", "minimum": 0 },
          "agent": {
            "type": "string",
            "enum": ["orchestrator", "intake", "matching", "kitchen", "donation", "delivery", "fallback"]
          },
          "type": { "type": "string", "enum": ["status", "thought", "tool_call", "check", "output"] },
          "title": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 },
          "data": { "type": "object" }
        }
      }
    }
  }
}
