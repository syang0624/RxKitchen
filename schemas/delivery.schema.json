{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nourishos.dev/schemas/delivery.schema.json",
  "title": "data/delivery.json — zones + DeliveryBatch[]",
  "type": "object",
  "additionalProperties": false,
  "required": ["zones", "batches"],
  "properties": {
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["zone", "depot_distance_mi", "cold_chain_limit_hours"],
        "properties": {
          "zone": { "type": "string", "minLength": 1 },
          "depot_distance_mi": { "type": "number", "minimum": 0 },
          "cold_chain_limit_hours": { "type": "number", "minimum": 0 }
        }
      }
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route_id", "zone", "clients", "window", "delivery_date", "cold_chain_ok"],
        "properties": {
          "route_id": { "type": "string", "pattern": "^R-[A-Z]{1,4}-[0-9]+$" },
          "zone": { "type": "string", "minLength": 1 },
          "clients": { "type": "array", "items": { "$ref": "defs.schema.json#/definitions/clientId" }, "minItems": 1, "maxItems": 12 },
          "window": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}–[0-9]{2}:[0-9]{2}$" },
          "delivery_date": { "$ref": "defs.schema.json#/definitions/isoDate" },
          "cold_chain_ok": { "type": "boolean" }
        }
      }
    }
  }
}
