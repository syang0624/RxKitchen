{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nourishos.dev/schemas/kitchen.schema.json",
  "title": "data/kitchen.json — KitchenCapacity[]",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["date", "labor_hours_available", "equipment_slots", "batch_min", "batch_max"],
    "properties": {
      "date": { "$ref": "defs.schema.json#/definitions/isoDate" },
      "labor_hours_available": { "type": "number", "minimum": 0 },
      "equipment_slots": { "type": "integer", "minimum": 0 },
      "batch_min": { "type": "integer", "minimum": 1 },
      "batch_max": { "type": "integer", "minimum": 1 }
    }
  }
}
