{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nourishos.dev/schemas/scenario.schema.json",
  "title": "data/scenarios/*.json — Scenario manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "client_id", "run", "description"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "title": { "type": "string", "minLength": 1 },
    "client_id": { "$ref": "defs.schema.json#/definitions/clientId" },
    "run": { "type": "string", "pattern": "^agent_runs/.+\\.json$" },
    "depleted_meal_id": { "$ref": "defs.schema.json#/definitions/mealId" },
    "donation_id": { "$ref": "defs.schema.json#/definitions/donationId" },
    "description": { "type": "string", "minLength": 1 }
  }
}
